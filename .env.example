GITHUB_API_TOKEN=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Public base URL of the deployed site (used for metadata, canonical URLs,
# sitemap.xml and robots.txt). Defaults to https://ulvidamirli.com.
NEXT_PUBLIC_SITE_URL=https://ulvidamirli.com

# All content lives in ONE GitHub Discussions category (default "Posts"),
# distinguished by labels: a type (Post / Project / Photo), a language
# (English / French) and "Draft" (drafts are hidden from the site). Only set
# this if you renamed the category.
GITHUB_POSTS_CATEGORY=Posts

# Giscus comments (https://giscus.app) via @giscus/react, mapping="pathname".
# Install the giscus GitHub App on the repo, then copy the repo id and the
# "Posts" category id from the giscus configurator. All values are public.
NEXT_PUBLIC_GISCUS_REPO=ulvidamirli/my_personal_website
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_POSTS_CATEGORY_ID=
